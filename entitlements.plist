<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Sandbox dropped because the bundled Tesseract binary is executed as a
        subprocess. Sandbox is incompatible with arbitrary subprocess spawning.
        The app remains fully offline (no network entitlement).

        The two entitlements below are required for notarisation when shipping
        with hardened runtime:

        - allow-unsigned-executable-memory: not strictly needed for our use,
          but harmless. Omitted intentionally — keep attack surface minimal.

        - disable-library-validation: REQUIRED. Tesseract loads dylibs from
          @executable_path/../Frameworks/. With hardened runtime + library
          validation on (the default), the OS only allows loading dylibs
          signed by the same Team ID OR Apple. Our bundled libs from Homebrew
          are signed ad-hoc, so we must disable library validation for the
          Tesseract subprocess. Without this, notarisation may succeed but
          Tesseract will fail to launch with code-signature errors on
          end-user machines.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
